# ============================================================
# GOLD SIGNAL PRO — Environment Variables untuk VPS
# Copy file ini: cp .env.example .env
# Lalu isi nilainya sesuai konfigurasi VPS Anda
# ============================================================

# PostgreSQL database connection string (WAJIB)
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
# Contoh: postgresql://postgres:password123@localhost:5432/goldsignal
DATABASE_URL=postgresql://postgres:PASSWORD@localhost:5432/goldsignal

# Port untuk API server (default: 5000)
API_PORT=5000

# Port untuk frontend (default: 3000)
FRONTEND_PORT=3000

# Secret untuk session (buat string random panjang)
# Generate: openssl rand -hex 32
SESSION_SECRET=ganti_dengan_random_string_panjang_minimal_32_karakter
